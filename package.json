{
  "name": "labour-board",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "pnpm --parallel --filter @labour-board/web --filter @labour-board/api dev",
    "dev:web": "pnpm --filter @labour-board/web dev",
    "dev:api": "pnpm --filter @labour-board/api dev",
    "build": "pnpm -r build",
    "build:web": "pnpm --filter @labour-board/web build",
    "build:api": "pnpm --filter @labour-board/api build",
    "build:shared": "pnpm --filter @labour-board/shared build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "prettier": "^3.8.3",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2"
  }
}
