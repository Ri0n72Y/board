{
  "name": "@labour-board/api",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.test.json",
    "lint": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.test.json",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.6",
    "@labour-board/shared": "workspace:*",
    "dotenv": "^17.2.3",
    "hono": "^4.10.7",
    "mongodb": "^7.0.0",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "@vitest/coverage-v8": "^4.1.7",
    "tsx": "^4.21.0",
    "typescript": "~6.0.2",
    "vitest": "^4.1.7"
  }
}
