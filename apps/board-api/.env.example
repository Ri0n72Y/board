# Server
PORT=8787

# MongoDB local development
# Use a local/dev database only. Never point this to production for test-data import.
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=labourboard_dev

# Legacy Agent integration placeholders
AGENT_PROVIDER=openai
AGENT_API_KEY=
AGENT_MODEL=
AGENT_BASE_URL=
AGENT_TIMEOUT_MS=30000
AGENT_ENABLED=false

# Agent Suggestion provider (MVP 2.5 — real provider enabled)
# Default is mock. Set to openai-compatible for real AI provider calls.
# Requires AGENT_SUGGESTION_BASE_URL, AGENT_SUGGESTION_API_KEY, and AGENT_SUGGESTION_MODEL.
# Provider errors (timeout, rate limit, HTTP error, output invalid) are mapped to
# distinct HTTP status codes. No silent fallback to mock.
AGENT_SUGGESTION_PROVIDER=mock
AGENT_SUGGESTION_MODEL=mock-suggestion-v1
AGENT_SUGGESTION_BASE_URL=
AGENT_SUGGESTION_API_KEY=
AGENT_SUGGESTION_MAX_INPUT_CHARS=200000
AGENT_SUGGESTION_MAX_OUTPUT_CHARS=50000
AGENT_SUGGESTION_MAX_ESTIMATED_INPUT_TOKENS=50000
AGENT_SUGGESTION_MAX_ESTIMATED_OUTPUT_TOKENS=12000
AGENT_SUGGESTION_TIMEOUT_MS=30000
AGENT_SUGGESTION_RETRY_MAX_ATTEMPTS=0

# Reserved as costBudgetCents. Parsed by backend config.
# Enforced placeholder; future real-provider cost tracking.
AGENT_SUGGESTION_COST_BUDGET_CENTS=
