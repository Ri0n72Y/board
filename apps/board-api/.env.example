# Server
PORT=8787

# MongoDB local development
# Use a local/dev database only. Never point this to production for test-data import.
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=labourboard_dev

# Agent integration placeholders
AGENT_PROVIDER=openai
AGENT_API_KEY=
AGENT_MODEL=
AGENT_BASE_URL=
AGENT_TIMEOUT_MS=30000
AGENT_ENABLED=false
